timeout 30
ui menu.c32
menu title Infidel's PXE boot Manager
MENU COLOR screen * #ffffffff #00000000 std
MENU COLOR border * #ff0000ff #00000000 std
MENU COLOR title * #ff00ffff #00000000 std
MENU COLOR sel * #ffffffff #ffff00ff none
MENU COLOR unsel * #ffffffff #00000000 std
default install
prompt 0


LABEL install
    MENU LABEL Install Ubuntu 20.04
    KERNEL ubuntu20.04/vmlinuz
    APPEND ip=dhcp url=https://aaaaaa/bbbb cloud-config-url=https://aaaaaa/bbbb ds=nocloud-net;s=https://aaaaaa/bbbb/metadata/ root=/dev/ram0

label localboot
    menu label Boot from Local Drive
    localboot 0
menu end

